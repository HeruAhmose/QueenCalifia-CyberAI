# Normalize line endings across platforms
* text=auto

# Enforce LF for common text formats (avoid CRLF/LF warnings)
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf

# Treat binaries as binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.pdf binary
*.woff binary
*.woff2 binary
